FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# 安裝依賴（強制安裝 devDependencies，避免 Zeabur 注入 NODE_ENV=production 導致跳過）
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/types/package.json ./packages/types/
RUN NODE_ENV=development pnpm install --frozen-lockfile

# 建置
FROM base AS builder
WORKDIR /app
COPY --from=deps /app ./
COPY . .
ARG NEXT_PUBLIC_API_URL=https://api.goboka.net/api
ARG NEXT_PUBLIC_SITE_URL=https://goboka.net
# NEXT_PUBLIC_* 於 Next.js prod build 為編譯時 inline，必須在 build 階段提供，
# 否則部署平台設 runtime env 也不會生效。此處預設正式 Pixel ID，
# 部署時可用 --build-arg 覆寫（staging 設空字串即關閉追蹤）。
ARG NEXT_PUBLIC_META_PIXEL_ID=1057718800020204
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_META_PIXEL_ID=$NEXT_PUBLIC_META_PIXEL_ID
RUN pnpm --filter @betting-forum/web build

# 生產環境
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
