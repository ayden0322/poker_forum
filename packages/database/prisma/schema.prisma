generator client {
  provider      = "prisma-client-js"
  // 本機 (macOS) + Docker 容器 (Alpine Linux) 都需要對應的 binary
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 會員 =====
model User {
  id              String     @id @default(cuid())
  nickname        String     @unique
  account         String?    @unique
  passwordHash    String?    @map("password_hash")
  email           String?    @unique
  avatar          String?
  level           Int        @default(1)
  role            Role       @default(USER)
  status          UserStatus @default(ACTIVE)
  lastLoginIp     String?    @map("last_login_ip")
  lastLoginAt     DateTime?  @map("last_login_at")
  phone           String?    @unique
  phoneVerified   Boolean    @default(false) @map("phone_verified")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  phoneChangedAt  DateTime?  @map("phone_changed_at")
  nicknameChangedAt DateTime? @map("nickname_changed_at")
  // 後台放行：勾選後等同已驗證手機，但 phoneVerified 仍為 false
  // 用於管理員 / 內部測試帳號免簡訊驗證；保留 phoneVerified 真假狀態以供稽核
  phoneVerificationBypass       Boolean   @default(false) @map("phone_verification_bypass")
  phoneVerificationBypassReason String?   @map("phone_verification_bypass_reason")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  oauthProviders     OAuthProvider[]
  posts              Post[]
  replies            Reply[]
  pushes             Push[]
  followers          Follow[]            @relation("following")
  following          Follow[]            @relation("follower")
  bookmarks          Bookmark[]
  notifications      Notification[]
  reports            Report[]            @relation("reporter")
  passwordResets     PasswordReset[]
  feedbacks          Feedback[]          @relation("FeedbackAuthor")
  feedbackReplies    FeedbackReply[]     @relation("FeedbackReplyAuthor")
  phoneVerifications PhoneVerification[]
  emailVerifications EmailVerification[]
  lotteryPicks       UserLotteryPick[]
  walletAccounts     WalletAccount[]
  dailyTaskProgress  DailyTaskProgress[]
  taskEventLog       TaskEventLog[]
  cosmetics          UserCosmetic[]
  promoReferral      PromoReferral?

  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

model OAuthProvider {
  id         String   @id @default(cuid())
  provider   String
  providerId String   @map("provider_id")
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@map("oauth_providers")
}

// ===== 看板 =====
// 分類型別：決定該分類底下看板可用的標籤集合（搭配 Tag.scope）
// SPORTS = 體育（籃球/足球/棒球/其他運動）；LOTTERY = 台灣彩票；GENERAL = 綜合（只吃通用標籤）
enum CategoryType {
  SPORTS
  LOTTERY
  GENERAL
}

model Category {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  // 分類型別；標籤可用集合 = scope=GLOBAL 的通用標籤 ∪ scope 對應此 type 的標籤
  type      CategoryType @default(GENERAL)
  sortOrder Int          @default(0) @map("sort_order")
  boards    Board[]

  @@map("categories")
}

model Board {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id])
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  posts       Post[]

  @@map("boards")
}

// ===== 文章 =====
enum PostStatus {
  DRAFT
  PUBLISHED
}

// 板塊頁分區（前台由上而下）：
// NEWS = 最新新聞（新聞 agent 自動發文審核通過後落此區）
// FEATURED = 站方公告（站方手動置頂 / 彩券公告等）
// DISCUSSION = 玩家討論（玩家發文，分頁）
enum PostSection {
  NEWS
  FEATURED
  DISCUSSION
}

model Post {
  id          String      @id @default(cuid())
  boardId     String      @map("board_id")
  board       Board       @relation(fields: [boardId], references: [id])
  authorId    String      @map("author_id")
  author      User        @relation(fields: [authorId], references: [id])
  title       String
  content     String      @db.Text
  status      PostStatus  @default(PUBLISHED)
  section     PostSection @default(DISCUSSION)
  isPinned    Boolean     @default(false) @map("is_pinned")
  isLocked    Boolean     @default(false) @map("is_locked")
  viewCount   Int         @default(0) @map("view_count")
  replyCount  Int         @default(0) @map("reply_count")
  pushCount   Int         @default(0) @map("push_count")
  // 最後活動時間：發文時等於 createdAt，之後 reply 來才更新。
  // 改為 non-null 以避免 ORDER BY lastReplyAt 時的 NULLS LAST/FIRST 行為不一致。
  lastReplyAt DateTime    @default(now()) @map("last_reply_at")
  lastReplyBy String?     @map("last_reply_by")
  // 新聞 Agent 自動發文標記：true 表示走「24h 自動退置頂 + 無互動回 DRAFT」生命週期
  // 彩券自動發文維持 false，不受相關 cron 影響
  isAutoPosted Boolean    @default(false) @map("is_auto_posted")
  // 置頂到期時間；到了 cron 會自動 unpin。null 表示永久置頂或未置頂
  pinnedUntil DateTime?   @map("pinned_until")
  // 首次發布時間（DRAFT→PUBLISHED 當下寫入）。新聞 24h 無互動退草稿 cron 以此為起算，
  // 避免「草稿放超過 24h 才審核通過、一上架就被秒退」。null 代表尚未發布或舊資料（cron 會 fallback createdAt）
  publishedAt DateTime?   @map("published_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  replies   Reply[]
  pushes    Push[]
  bookmarks Bookmark[]
  tags      PostTag[]
  reports   Report[]

  @@index([boardId, createdAt])
  @@index([boardId, lastReplyAt])
  @@index([boardId, status])
  @@index([boardId, section])
  @@index([authorId])
  @@index([isAutoPosted, isPinned, pinnedUntil])
  @@index([isAutoPosted, status, createdAt])
  @@index([isAutoPosted, status, publishedAt])
  @@map("posts")
}

model PostTag {
  id     String @id @default(cuid())
  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String @map("tag_id")
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@unique([postId, tagId])
  @@map("post_tags")
}

// 標籤適用範圍：決定哪些分類的看板能用此標籤（搭配 Category.type）
// GLOBAL = 通用（所有看板）；SPORTS = 體育共用；LOTTERY = 彩券專用
enum TagScope {
  GLOBAL
  SPORTS
  LOTTERY
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  // 適用範圍；發文頁與篩選列依「board.category.type」決定要顯示哪些標籤
  scope     TagScope  @default(GLOBAL)
  // UI 顯示順序（同 scope 內由小到大）
  sortOrder Int       @default(0) @map("sort_order")
  posts     PostTag[]

  @@map("tags")
}

// ===== 回覆 =====
model Reply {
  id            String   @id @default(cuid())
  postId        String   @map("post_id")
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId      String   @map("author_id")
  author        User     @relation(fields: [authorId], references: [id])
  floorNumber   Int      @map("floor_number")
  content       String   @db.Text
  quotedReplyId String?  @map("quoted_reply_id")
  quotedReply   Reply?   @relation("QuotedReply", fields: [quotedReplyId], references: [id])
  quotes        Reply[]  @relation("QuotedReply")
  pushCount     Int      @default(0) @map("push_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  pushes  Push[]
  reports Report[]

  @@index([postId, floorNumber])
  @@map("replies")
}

// ===== 推文 =====
model Push {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?  @map("post_id")
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId   String?  @map("reply_id")
  reply     Reply?   @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@map("pushes")
}

// ===== 追蹤 =====
model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String   @map("following_id")
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@map("follows")
}

// ===== 收藏 =====
model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@map("bookmarks")
}

// ===== 通知 =====
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  content   String
  sourceUrl String?          @map("source_url")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  REPLY
  PUSH
  FOLLOW
  SYSTEM
}

// ===== 檢舉 =====
model Report {
  id         String       @id @default(cuid())
  reporterId String       @map("reporter_id")
  reporter   User         @relation("reporter", fields: [reporterId], references: [id])
  postId     String?      @map("post_id")
  post       Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId    String?      @map("reply_id")
  reply      Reply?       @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@map("reports")
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ===== 封鎖 IP =====
model BannedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banned_ips")
}

// ===== 彩券開獎 =====
model LotteryResult {
  id          String   @id @default(cuid())
  gameType    String   @map("game_type")
  period      String
  drawDate    DateTime @map("draw_date")
  numbers     Json
  specialNum  Json?    @map("special_num")
  jackpot     BigInt?
  totalSales  BigInt?  @map("total_sales")
  prizeDetail Json?    @map("prize_detail")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([gameType, period])
  @@index([gameType, drawDate])
  @@map("lottery_results")
}

// 使用者收藏的「我的號碼組」
// 開獎後與最新一期比對，計算中獎顆數
model UserLotteryPick {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType   String   @map("game_type") // LOTTO649 / SUPER_LOTTO / DAILY539 / LOTTO1224 / LOTTO3D / LOTTO4D
  label      String   // 使用者自訂的組名，如「我的固定組合」
  numbers    Json     // 主號碼陣列 [7, 12, 22, ...]
  specialNum Json?    @map("special_num") // 特別號（大樂透/威力彩才有）
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, gameType])
  @@map("user_lottery_picks")
}

// ===== 跑馬燈 =====
model Marquee {
  id        String   @id @default(cuid())
  content   String
  url       String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("marquees")
}

// ===== 意見回報 =====
model Feedback {
  id        String         @id @default(cuid())
  authorId  String         @map("author_id")
  author    User           @relation("FeedbackAuthor", fields: [authorId], references: [id])
  type      FeedbackType
  title     String
  content   String         @db.Text
  status    FeedbackStatus @default(PENDING)
  replies   FeedbackReply[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([status])
  @@index([type])
  @@map("feedbacks")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String   @map("feedback_id")
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation("FeedbackReplyAuthor", fields: [authorId], references: [id])
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([feedbackId])
  @@map("feedback_replies")
}

enum FeedbackType {
  BUG
  SUGGESTION
}

enum FeedbackStatus {
  PENDING
  REVIEWING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ===== 密碼重設 =====
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_resets")
}

// ===== 手機驗證 =====
model PhoneVerification {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String
  codeHash   String        @map("code_hash")
  purpose    VerifyPurpose
  attempts   Int           @default(0)
  expiresAt  DateTime      @map("expires_at")
  consumedAt DateTime?     @map("consumed_at")
  ip         String?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@index([phone])
  @@map("phone_verifications")
}

enum VerifyPurpose {
  BIND
  CHANGE
}

// ===== Email 驗證（用於換綁手機等情境） =====
model EmailVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String           @unique
  purpose   EmailVerifyPurpose
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@map("email_verifications")
}

enum EmailVerifyPurpose {
  PHONE_CHANGE
}

// ===== 簡訊服務商設定（後台可編輯） =====
model SmsProviderConfig {
  id           String   @id @default(cuid())
  providerCode String   @unique @map("provider_code")
  displayName  String   @map("display_name")
  enabled      Boolean  @default(false)
  apiEndpoint  String   @map("api_endpoint")
  apiKeyEnc    String   @map("api_key_enc")
  apiSecretEnc String?  @map("api_secret_enc")
  senderId     String?  @map("sender_id")
  templateId   String?  @map("template_id")
  extraConfig  Json?    @map("extra_config")
  updatedBy    String?  @map("updated_by")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sms_provider_configs")
}

// ===== 實體名稱翻譯（通用，支援多種類型） =====
// entityType: team, player, league, coach, venue, country
model Translation {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")       // team | player | league | coach | venue | country
  apiId       Int      @map("api_id")            // API-Sports 的實體 ID
  sport       String                              // football | basketball | baseball
  nameEn      String   @map("name_en")
  nameZhTw    String   @map("name_zh_tw")
  shortName   String?  @map("short_name")        // 簡稱（如：湖人、曼聯）
  nickname    String?                             // 暱稱（如：詹皇、一哥）
  logo        String?                             // 快取 logo/photo URL
  source      String   @default("ai")            // ai | manual | official
  verified    Boolean  @default(false)           // 是否經人工校正
  bio         String?  @db.Text                   // 長文簡介（球員/球隊介紹，選填）
  bioZhTw     String?  @db.Text @map("bio_zh_tw") // 中文簡介
  extra       Json?                               // 額外欄位（位置、球衣號等）
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([entityType, apiId, sport])
  @@index([entityType, sport])
  @@index([verified])
  @@map("translations")
}

// ===== 翻譯使用量紀錄（成本監控） =====
model TranslationUsage {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  model          String                           // claude-haiku-4-5
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  costUsd        Float    @map("cost_usd")
  entityType     String?  @map("entity_type")    // 翻譯哪類實體
  itemCount      Int      @map("item_count")     // 這次翻了幾個
  triggeredBy    String   @default("cron") @map("triggered_by") // cron | manual
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("translation_usage")
}

// ===== FIFA 世界盃 2026（DB-first，資料源 GitHub openfootball/worldcup.json） =====
// 與一般 sports 模組分離：世界盃為 4 年一次的特殊賽事，
// 資料量小且有明確開始/結束，獨立表更易維護
model WorldCupTeam {
  id        Int     @id @default(autoincrement())
  fifaCode  String  @unique @map("fifa_code")     // "MEX"
  nameEn    String  @map("name_en")               // "Mexico"
  nameZh    String? @map("name_zh")               // "墨西哥"（翻譯後填入）
  flagEmoji String? @map("flag_emoji")            // "🇲🇽"
  groupName String? @map("group_name")            // "A" ~ "L"
  continent String?                                // "North America"
  confed    String?                                // "CONCACAF"
  // ⚠️ 2026-05-18 暫時註解（schema 加了但 DB 沒同步，造成 migration drift）
  //    待 World Cup api-sports 整合 feature 動工時，再連同 seed-world-cup-from-apisports.ts 一起恢復
  // apiTeamId Int?    @unique @map("api_team_id")   // api-sports team ID
  // logoUrl   String? @map("logo_url")              // api-sports 隊徽 URL
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  matchesAsHome WorldCupMatch[] @relation("HomeTeam")
  matchesAsAway WorldCupMatch[] @relation("AwayTeam")

  @@index([groupName])
  @@map("world_cup_teams")
}

model WorldCupMatch {
  id              Int      @id @default(autoincrement())
  matchNumber     Int      @unique @map("match_number")    // 1~104
  round           String                                    // "Matchday 1" / "Round of 32" / "Final"
  stage           String                                    // "group" | "knockout"
  groupName       String?  @map("group_name")              // 小組賽才有 "Group A"
  kickoffAt       DateTime @map("kickoff_at")              // UTC
  venue           String
  // ⚠️ 2026-05-18 暫時註解（schema 加了但 DB 沒同步，造成 migration drift）
  //    待 World Cup api-sports 整合 feature 動工時，再連同 seed-world-cup-from-apisports.ts 一起恢復
  // venueCity       String?  @map("venue_city")              // api-sports 提供的城市
  // apiFixtureId    Int?     @unique @map("api_fixture_id")  // api-sports fixture ID

  homeTeamId      Int?     @map("home_team_id")
  awayTeamId      Int?     @map("away_team_id")
  homeTeam        WorldCupTeam? @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        WorldCupTeam? @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homePlaceholder String?  @map("home_placeholder")        // 淘汰賽 "W101" 之類
  awayPlaceholder String?  @map("away_placeholder")

  homeScore       Int?     @map("home_score")
  awayScore       Int?     @map("away_score")
  status          String   @default("scheduled")           // scheduled | live | finished
  liveMinute      Int?     @map("live_minute")             // 進行中的分鐘（0~90+）

  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([kickoffAt])
  @@index([groupName])
  @@index([stage])
  @@index([status])
  @@map("world_cup_matches")
}

// ===== 國際足球友誼賽（API-Sports league=10 Cup Friendlies）=====
// 刻意與 World Cup 完全隔離：友誼賽沒有小組/淘汰賽結構，且需要 api_fixture_id / logo_url
// 等欄位（World Cup 的同名欄位因 2026-05-18 migration drift 被註解掉，新 model 直接繞開那顆雷）。
model FriendlyTeam {
  id        Int     @id @default(autoincrement())
  apiTeamId Int     @unique @map("api_team_id")     // api-sports team ID
  nameEn    String  @map("name_en")                 // "Germany"
  nameZh    String? @map("name_zh")                 // "德國"（翻譯後填入）
  logoUrl   String? @map("logo_url")                // api-sports 隊徽 URL（真 logo）
  country   String?                                  // 國家名（國家隊）
  isMarquee Boolean @default(false) @map("is_marquee")  // 是否為強隊（焦點戰判斷用）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  matchesAsHome FriendlyMatch[] @relation("FriendlyHome")
  matchesAsAway FriendlyMatch[] @relation("FriendlyAway")

  @@map("friendly_teams")
}

model FriendlyMatch {
  id           Int      @id @default(autoincrement())
  apiFixtureId Int      @unique @map("api_fixture_id")   // api-sports fixture ID（去重主鍵）
  season       Int                                        // 2026
  round        String?                                    // api-sports round 文字
  kickoffAt    DateTime @map("kickoff_at")               // UTC
  venue        String?
  venueCity    String?  @map("venue_city")

  homeTeamId Int          @map("home_team_id")
  awayTeamId Int          @map("away_team_id")
  homeTeam   FriendlyTeam @relation("FriendlyHome", fields: [homeTeamId], references: [id])
  awayTeam   FriendlyTeam @relation("FriendlyAway", fields: [awayTeamId], references: [id])

  homeScore   Int?    @map("home_score")
  awayScore   Int?    @map("away_score")
  status      String  @default("scheduled")              // scheduled | live | finished
  statusShort String? @map("status_short")               // 原始 api short code（FT/NS/1H...）
  liveMinute  Int?    @map("live_minute")                // 進行中的分鐘

  // 焦點戰白名單：只有 isFeatured=true 的場次才生成可索引頁面，其餘 noindex
  // （避免 488 場薄頁面反傷整站 SEO quality signal）
  isFeatured  Boolean @default(false) @map("is_featured")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([kickoffAt])
  @@index([status])
  @@index([isFeatured])
  @@map("friendly_matches")
}

// ===== 管理員操作稽核日誌 =====
// 紀錄管理員執行的敏感操作，例如代登入會員、密碼重設等
// 動作分類用 string 而非 enum，方便未來新增動作不需 migration
model AuditLog {
  id            String   @id @default(cuid())
  actorAdminId  String   @map("actor_admin_id")  // 執行動作的管理員 ID
  actorNickname String   @map("actor_nickname")  // 快照當下的暱稱，避免 admin 改名後失真
  action        String                            // IMPERSONATE_START | IMPERSONATE_STOP | RESET_PASSWORD | ...
  targetUserId  String?  @map("target_user_id")   // 被操作的目標會員 ID（可為 null，例如系統設定變更）
  targetNickname String? @map("target_nickname")
  metadata      Json?                             // 額外資訊（IP、reason、tokenJti…）
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([actorAdminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ===== 體育賽事 API 設定（後台可編輯） =====
model SportsConfig {
  id          String   @id @default(cuid())
  boardSlug   String   @unique @map("board_slug")      // 對應 Board.slug（如 nba, cba, epl）
  sportType   String   @map("sport_type")              // football, basketball, baseball
  displayName String   @map("display_name")            // NBA, CBA, 英超
  enabled     Boolean  @default(true)
  apiHost     String   @map("api_host")                // API-Sports base host
  leagueId    Int      @map("league_id")
  season      String                                    // 賽季（如 2026, 2025-2026）
  cacheTtl    Json     @default("{}") @map("cache_ttl") // { live: 60, schedule: 300, ... }
  extraConfig Json?    @map("extra_config")             // 額外設定
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sportType])
  @@map("sports_configs")
}

// ===== 後台頁面權限矩陣（僅超級管理員可編輯） =====
// 每個後台頁面（pageKey）對三個層級各有一個可見開關。
// 採「每層獨立布林」而非「最低層級」，以支援非單調設定（例如某頁開放給總管理員、卻對超級管理員隱藏）。
// 「權限設定」頁本身永遠對超級管理員開放（防鎖死，於 service 層硬性保證）。
model AdminPagePermission {
  id              String   @id @default(cuid())
  pageKey         String   @unique @map("page_key")
  allowModerator  Boolean  @default(false) @map("allow_moderator")  // 編輯人員
  allowAdmin      Boolean  @default(false) @map("allow_admin")      // 總管理員
  allowSuperAdmin Boolean  @default(true) @map("allow_super_admin") // 超級管理員
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("admin_page_permissions")
}

// ===== 會員經濟（G幣/P幣 帳本） =====
// 設計：錢包存「目前餘額」，帳本（ledger）append-only 記每一筆異動。
// 任何時點餘額 = 該帳戶所有 ledger amount 的累加（可稽核）。
// 發/扣幣一律帶 idempotencyKey（@unique），同 key 重送不重複入帳。

enum Currency {
  G   // G幣：行為獎勵、論壇積分
  P   // P幣：預測籌碼（只能用 G幣換）
  EXP // 經驗值：只增不減、用來升等（沿用帳本機制取得冪等與稽核）
}

enum LedgerReason {
  TASK_REWARD       // 每日任務獎勵
  SHOP_PURCHASE     // 裝飾商店購買（扣）
  SHOP_REFUND       // 商店退款（入）
  EXCHANGE_G_TO_P   // G→P 兌換
  PREDICTION_STAKE  // 預測下注（扣 P）
  PREDICTION_PAYOUT // 預測派彩（入 P）
  PREDICTION_REFUND // 延賽/平盤退本（入 P）
  ADMIN_ADJUST      // 後台手動調整
}

model WalletAccount {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  Currency
  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ledgerEntries LedgerEntry[]

  @@unique([userId, currency])
  @@map("wallet_accounts")
}

model LedgerEntry {
  id             String        @id @default(cuid())
  accountId      String        @map("account_id")
  account        WalletAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount         Int // 正=入帳、負=出帳
  reason         LedgerReason
  refType        String?       @map("ref_type") // 關聯來源類型（如 task / shopOrder / bet）
  refId          String?       @map("ref_id")
  idempotencyKey String        @unique @map("idempotency_key")
  balanceAfter   Int           @map("balance_after") // 此筆異動後的餘額快照
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([accountId, createdAt])
  @@map("ledger_entries")
}

// 等級門檻（程式定義預設 + 開機自動 seed，之後可後台覆蓋）。
// minExp = null 代表非經驗門檻（邀請制，如 Lv5 名人堂），不會被經驗自動升上去。
model LevelTier {
  level     Int      @id // 1..5
  name      String
  minExp    Int?     @map("min_exp")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("level_tiers")
}

// ===== 每日任務 =====
// 任務「類型」由程式定義（綁事件）；獎勵數值程式預設 + seed，後台 CRUD 為後續增量。

enum DailyTaskKey {
  LOGIN       // 每日登入
  VIEW_POSTS  // 瀏覽 5 篇文章
  CREATE_POST // 發表 1 篇文章
  REPLY       // 回覆 3 篇文章
  LIKE        // 按讚 5 次
}

model DailyTaskDef {
  taskKey   DailyTaskKey @id @map("task_key")
  label     String
  rewardG   Int          @map("reward_g")
  rewardExp Int          @map("reward_exp")
  threshold Int          @default(1) // 達成門檻：瀏覽5篇=5、回覆3篇=3、按讚5次=5、登入/發文=1
  enabled   Boolean      @default(true)
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("daily_task_defs")
}

// 任務事件去重計數（多次行為才達標的任務用，如瀏覽5篇/按讚5次/回覆3篇）。
// refId = 行為對象（postId 等）；同一 refId 當日只計一次。
model TaskEventLog {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskKey   DailyTaskKey @map("task_key")
  refId     String       @map("ref_id")
  taskDate  String       @map("task_date") // 台灣日 YYYY-MM-DD
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([userId, taskKey, refId, taskDate])
  @@index([userId, taskKey, taskDate])
  @@map("task_event_log")
}

// 每日任務完成紀錄（一天一次去重；taskDate 為台灣日 YYYY-MM-DD）。
model DailyTaskProgress {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskKey     DailyTaskKey @map("task_key")
  taskDate    String       @map("task_date") // 台灣日 YYYY-MM-DD
  completedAt DateTime     @default(now()) @map("completed_at")

  @@unique([userId, taskKey, taskDate])
  @@index([userId, taskDate])
  @@map("daily_task_progress")
}

// ===== 裝飾商店（頭像框 / 勳章 / 稱號）=====
// 純虛擬：只用 G幣兌換、永久擁有、不可儲值真錢、不可提現。購買走 LedgerReason.SHOP_PURCHASE。
// 顏色一律由 rarity 決定（前端 token），不存自由填色。

enum CosmeticType {
  FRAME // 頭像框
  BADGE // 勳章
  TITLE // 稱號
}

enum Rarity {
  COMMON    // 普通（中性灰/青綠淺）
  RARE      // 稀有（青綠 #39B8BE 實心）
  LEGENDARY // 傳說（琥珀金 #d97706 金邊）
}

enum CosmeticSource {
  SHOP  // G幣購買
  LEVEL // 等級解鎖
  EVENT // 賽事/活動獎勵（二期排行榜永久紀念勳章走這）
}

enum EquipSlot {
  FRAME
  TITLE
}

// 裝飾品項（後台 CRUD）。
model CosmeticItem {
  id            String       @id @default(cuid())
  type          CosmeticType
  name          String
  description   String?
  // Route A：框=CSS環(只看rarity)、勳章=lucide(存iconKey)、稱號=有色文字。視覺一律由 rarity 驅動。
  iconKey       String?      @map("icon_key") // 僅勳章填 lucide 名稱(如 message-square)；框/稱號留空
  rarity        Rarity       @default(COMMON)
  priceG        Int?         @map("price_g")        // null = 非販售品（純等級/賽事獲得）
  purchasable   Boolean      @default(true)         // 是否販售中（停售=false，不影響已擁有者）
  levelRequired Int?         @map("level_required") // 購買需求等級（null=無）
  enabled       Boolean      @default(true)         // 撤除開關(moderation)：false → 全站隱藏 + 卸下，罕用
  availableFrom DateTime?    @map("available_from") // 限時上架（null=不限）
  availableTo   DateTime?    @map("available_to")
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  userCosmetics UserCosmetic[]

  @@index([type, enabled])
  @@map("cosmetic_items")
}

// 使用者擁有 + 裝備/展示狀態（單一路徑：擁有、裝備、釘選都在這）。
// DB 不變量（migration 補 partial unique）：
//   每使用者每槽至多 1 件裝備、至多 1 枚主勳章、釘選位不重複。
model UserCosmetic {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId       String         @map("item_id")
  // Restrict：有人擁有的品項不可被硬刪（DB 層保證；下架請用 purchasable=false / enabled=false）
  item         CosmeticItem   @relation(fields: [itemId], references: [id], onDelete: Restrict)
  source       CosmeticSource @default(SHOP)
  acquiredAt   DateTime       @default(now()) @map("acquired_at")
  equippedSlot EquipSlot?     @map("equipped_slot") // FRAME/TITLE 裝備中；勳章一律 null
  isMainBadge  Boolean        @default(false) @map("is_main_badge") // 列表內聯展示的那 1 枚
  pinnedOrder  Int?           @map("pinned_order")  // 個人頁釘選 1..3；null=未釘

  @@unique([userId, itemId]) // 同品項只擁有一份（防重複購買）
  @@index([userId])
  @@map("user_cosmetics")
}

// ===== 推廣碼（廠商推廣歸因 + 漏斗）=====
// 業主對外找推廣廠商導流註冊：每家廠商可有多組碼（分渠道），
// 使用者經專屬連結 /r/<code> 落地 → 註冊時自動歸因到該碼，量化點擊→註冊→手機驗證漏斗。

enum PromoStatus {
  ACTIVE
  DISABLED
}

// 推廣廠商：一家廠商底下可掛多組推廣碼（FB/IG/LINE 等渠道各一）。
model PromoPartner {
  id          String      @id @default(cuid())
  name        String // 廠商名稱
  contact     String? // 聯絡方式
  note        String?
  status      PromoStatus @default(ACTIVE)
  createdById String?     @map("created_by_id") // 建立者（管理員 userId 快照，不設 FK 以免刪管理員連動）
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  codes PromoCode[]

  @@map("promo_partners")
}

// 推廣碼：URL-safe 短碼，屬於某廠商，可標記渠道與到期。
model PromoCode {
  id        String      @id @default(cuid())
  code      String      @unique // 短碼，如 FB2026（大小寫不敏感由 service 統一轉大寫存取）
  partnerId String      @map("partner_id")
  partner   PromoPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  channel   String? // 渠道標記（FB/IG/LINE…）
  status    PromoStatus @default(ACTIVE)
  expiresAt DateTime?   @map("expires_at")
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  visits    PromoVisit[]
  referrals PromoReferral[]

  @@index([partnerId])
  @@map("promo_codes")
}

// 點擊/落地日誌（漏斗上層）。同訪客同碼只算一次不重複點擊；bot 標記後不計入頭條數。
model PromoVisit {
  id        String    @id @default(cuid())
  codeId    String    @map("code_id")
  code      PromoCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  visitorId String    @map("visitor_id") // cookie 內匿名隨機 id，去重 + 串接註冊
  ip        String?
  userAgent String?   @map("user_agent")
  isBot     Boolean   @default(false) @map("is_bot")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([codeId, visitorId])
  @@index([codeId, createdAt])
  @@map("promo_visits")
}

// 註冊歸因（漏斗下層）。一個 user 最多一筆（unique userId）。
// 手機驗證數不另存欄位，報表時 join User.phoneVerified（權威來源，避免漂移）。
model PromoReferral {
  id        String    @id @default(cuid())
  codeId    String    @map("code_id")
  code      PromoCode @relation(fields: [codeId], references: [id])
  userId    String    @unique @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitorId String?   @map("visitor_id") // 對應點擊，串起漏斗
  regIp     String?   @map("reg_ip") // 結算抗詐：同 IP 多註冊偵測
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([codeId, createdAt])
  @@map("promo_referrals")
}
