generator client {
  provider      = "prisma-client-js"
  // 本機 (macOS) + Docker 容器 (Alpine Linux) 都需要對應的 binary
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 會員 =====
model User {
  id              String     @id @default(cuid())
  nickname        String     @unique
  account         String?    @unique
  passwordHash    String?    @map("password_hash")
  email           String?    @unique
  avatar          String?
  level           Int        @default(1)
  role            Role       @default(USER)
  status          UserStatus @default(ACTIVE)
  lastLoginIp     String?    @map("last_login_ip")
  lastLoginAt     DateTime?  @map("last_login_at")
  phone           String?    @unique
  phoneVerified   Boolean    @default(false) @map("phone_verified")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  phoneChangedAt  DateTime?  @map("phone_changed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  oauthProviders     OAuthProvider[]
  posts              Post[]
  replies            Reply[]
  pushes             Push[]
  followers          Follow[]            @relation("following")
  following          Follow[]            @relation("follower")
  bookmarks          Bookmark[]
  notifications      Notification[]
  reports            Report[]            @relation("reporter")
  passwordResets     PasswordReset[]
  feedbacks          Feedback[]          @relation("FeedbackAuthor")
  feedbackReplies    FeedbackReply[]     @relation("FeedbackReplyAuthor")
  phoneVerifications PhoneVerification[]
  emailVerifications EmailVerification[]

  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

model OAuthProvider {
  id         String   @id @default(cuid())
  provider   String
  providerId String   @map("provider_id")
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@map("oauth_providers")
}

// ===== 看板 =====
model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  sortOrder Int     @default(0) @map("sort_order")
  boards    Board[]

  @@map("categories")
}

model Board {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id])
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  posts       Post[]

  @@map("boards")
}

// ===== 文章 =====
model Post {
  id          String    @id @default(cuid())
  boardId     String    @map("board_id")
  board       Board     @relation(fields: [boardId], references: [id])
  authorId    String    @map("author_id")
  author      User      @relation(fields: [authorId], references: [id])
  title       String
  content     String    @db.Text
  isPinned    Boolean   @default(false) @map("is_pinned")
  isLocked    Boolean   @default(false) @map("is_locked")
  isAnnounce  Boolean   @default(false) @map("is_announce")
  viewCount   Int       @default(0) @map("view_count")
  replyCount  Int       @default(0) @map("reply_count")
  pushCount   Int       @default(0) @map("push_count")
  lastReplyAt DateTime? @map("last_reply_at")
  lastReplyBy String?   @map("last_reply_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  replies   Reply[]
  pushes    Push[]
  bookmarks Bookmark[]
  tags      PostTag[]
  reports   Report[]

  @@index([boardId, createdAt])
  @@index([boardId, lastReplyAt])
  @@index([authorId])
  @@map("posts")
}

model PostTag {
  id     String @id @default(cuid())
  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String @map("tag_id")
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@unique([postId, tagId])
  @@map("post_tags")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

// ===== 回覆 =====
model Reply {
  id            String   @id @default(cuid())
  postId        String   @map("post_id")
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId      String   @map("author_id")
  author        User     @relation(fields: [authorId], references: [id])
  floorNumber   Int      @map("floor_number")
  content       String   @db.Text
  quotedReplyId String?  @map("quoted_reply_id")
  quotedReply   Reply?   @relation("QuotedReply", fields: [quotedReplyId], references: [id])
  quotes        Reply[]  @relation("QuotedReply")
  pushCount     Int      @default(0) @map("push_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  pushes  Push[]
  reports Report[]

  @@index([postId, floorNumber])
  @@map("replies")
}

// ===== 推文 =====
model Push {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?  @map("post_id")
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId   String?  @map("reply_id")
  reply     Reply?   @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@map("pushes")
}

// ===== 追蹤 =====
model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String   @map("following_id")
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@map("follows")
}

// ===== 收藏 =====
model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@map("bookmarks")
}

// ===== 通知 =====
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  content   String
  sourceUrl String?          @map("source_url")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  REPLY
  PUSH
  FOLLOW
  SYSTEM
}

// ===== 檢舉 =====
model Report {
  id         String       @id @default(cuid())
  reporterId String       @map("reporter_id")
  reporter   User         @relation("reporter", fields: [reporterId], references: [id])
  postId     String?      @map("post_id")
  post       Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId    String?      @map("reply_id")
  reply      Reply?       @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@map("reports")
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ===== 封鎖 IP =====
model BannedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banned_ips")
}

// ===== 彩券開獎 =====
model LotteryResult {
  id          String   @id @default(cuid())
  gameType    String   @map("game_type")
  period      String
  drawDate    DateTime @map("draw_date")
  numbers     Json
  specialNum  Json?    @map("special_num")
  jackpot     BigInt?
  totalSales  BigInt?  @map("total_sales")
  prizeDetail Json?    @map("prize_detail")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([gameType, period])
  @@index([gameType, drawDate])
  @@map("lottery_results")
}

// ===== 跑馬燈 =====
model Marquee {
  id        String   @id @default(cuid())
  content   String
  url       String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("marquees")
}

// ===== 意見回報 =====
model Feedback {
  id        String         @id @default(cuid())
  authorId  String         @map("author_id")
  author    User           @relation("FeedbackAuthor", fields: [authorId], references: [id])
  type      FeedbackType
  title     String
  content   String         @db.Text
  status    FeedbackStatus @default(PENDING)
  replies   FeedbackReply[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([status])
  @@index([type])
  @@map("feedbacks")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String   @map("feedback_id")
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation("FeedbackReplyAuthor", fields: [authorId], references: [id])
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([feedbackId])
  @@map("feedback_replies")
}

enum FeedbackType {
  BUG
  SUGGESTION
}

enum FeedbackStatus {
  PENDING
  REVIEWING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ===== 密碼重設 =====
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_resets")
}

// ===== 手機驗證 =====
model PhoneVerification {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String
  codeHash   String        @map("code_hash")
  purpose    VerifyPurpose
  attempts   Int           @default(0)
  expiresAt  DateTime      @map("expires_at")
  consumedAt DateTime?     @map("consumed_at")
  ip         String?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@index([phone])
  @@map("phone_verifications")
}

enum VerifyPurpose {
  BIND
  CHANGE
}

// ===== Email 驗證（用於換綁手機等情境） =====
model EmailVerification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String           @unique
  purpose   EmailVerifyPurpose
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@map("email_verifications")
}

enum EmailVerifyPurpose {
  PHONE_CHANGE
}

// ===== 簡訊服務商設定（後台可編輯） =====
model SmsProviderConfig {
  id           String   @id @default(cuid())
  providerCode String   @unique @map("provider_code")
  displayName  String   @map("display_name")
  enabled      Boolean  @default(false)
  apiEndpoint  String   @map("api_endpoint")
  apiKeyEnc    String   @map("api_key_enc")
  apiSecretEnc String?  @map("api_secret_enc")
  senderId     String?  @map("sender_id")
  templateId   String?  @map("template_id")
  extraConfig  Json?    @map("extra_config")
  updatedBy    String?  @map("updated_by")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sms_provider_configs")
}

// ===== 體育賽事 API 設定（後台可編輯） =====
model SportsConfig {
  id          String   @id @default(cuid())
  sportType   String   @unique @map("sport_type")    // baseball, basketball, soccer
  displayName String   @map("display_name")           // 棒球, 籃球, 足球
  enabled     Boolean  @default(true)
  apiHost     String   @map("api_host")               // API-Sports base host
  leagueId    Int      @map("league_id")
  season      String                                   // 賽季（如 2026, 2025-2026）
  cacheTtl    Json     @default("{}") @map("cache_ttl") // { live: 60, schedule: 300, ... }
  extraConfig Json?    @map("extra_config")            // 額外設定（多聯賽等）
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("sports_configs")
}
