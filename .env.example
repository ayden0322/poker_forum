# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/betting_forum?schema=public"

# Redis
REDIS_URL="redis://localhost:6380"

# JWT（生產環境請替換為獨立的強密鑰，至少 32 字元）
JWT_SECRET="your-jwt-secret-at-least-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-at-least-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# OAuth - Google（至 Google Cloud Console 申請）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4010/api/auth/google/callback"

# OAuth - Facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:4010/api/auth/facebook/callback"

# OAuth - LINE
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_CALLBACK_URL="http://localhost:4010/api/auth/line/callback"

# Frontend URLs
WEB_URL="http://localhost:3010"
ADMIN_URL="http://localhost:3011"
API_URL="http://localhost:4010"

# CORS（逗號分隔的允許來源）
CORS_ORIGINS="http://localhost:3010,http://localhost:3011"

# MinIO（S3 相容物件儲存）
MINIO_ENDPOINT="localhost"
MINIO_PORT=9100
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="avatars"
MINIO_USE_SSL=false

# Upload
MAX_FILE_SIZE=2097152

# 敏感資料加密金鑰（用於 SMS 廠商 API Key 的加密儲存）
# 產生方式：openssl rand -hex 32
# ⚠️ 一旦設定後不可變更，否則既有加密資料會無法解密
# ⚠️ 本地、正式環境請使用不同金鑰
ENCRYPTION_KEY=""

# Email 服務（Zeabur ZSend）
MAIL_DRIVER="zsend"                                    # zsend | log（log 僅開發用，輸出到 console）
ZSEND_API_ENDPOINT="https://api.zsend.zeabur.com/v1/mail/send"
ZSEND_API_KEY=""                                       # 從 Zeabur ZSend 後台取得
MAIL_FROM="noreply@goboka.net"                         # 建議使用你的論壇網域
MAIL_FROM_NAME="博客邦"

# TA 國際簡訊平台（向業務員取得）
TA_SMS_API_KEY=""
TA_SMS_USERNAME=""
